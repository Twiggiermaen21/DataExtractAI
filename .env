LLM_MODEL=qwen/qwen3.5-9b
# LLM_MODEL=google/gemma-3-4b

# LLM_API_URL=http://192.168.1.61:1234/v1/chat/completions
# LLM_API_URL=http://127.0.0.1:1234/v1/chat/completions
LLM_MAX_TOKENS=20000

# === Llama Server Konfiguracja Modeli ===
# Odkomentuj wybraną parę (model + mmproj) 

# --- Opcja 1: Qwen 3.5 2B (Domyślnie używany) ---
# LLM_MODEL_FILE=Qwen3.5-2B.gguf
# LLM_MMPROJ_FILE=mmproj-Qwen3.5-2B.gguf

# --- Opcja 2: Qwen 3.5 9B ---
# LLM_MODEL_FILE=qwen3.5-9b.gguf
# LLM_MMPROJ_FILE=mmproj-Qwen3.5-9B.gguf
# LLM_MMPROJ_FILE=mmproj-Qwen3.5-9B-BF16.gguf

# --- Opcja 3: Gemma 3 4B ---
# LLM_MODEL_FILE=gemma-3-4b.gguf
# LLM_MODEL_FILE=gemma-3-4b-it-Q4_K_M.gguf
# LLM_MMPROJ_FILE=mmproj-gemma-3-4b-it.gguf

# --- Opcja 4: Qwen 3 VL 4B Instruct (Q4) ---
# LLM_MODEL_FILE=Qwen3VL-4B-Instruct-Q4_K_M.gguf
# LLM_MMPROJ_FILE=mmproj-Qwen3-VL-4B-Instruct-F16.gguf

# --- Opcja 5: Qwen 3 VL 4B Instruct (Q8) ---
LLM_MODEL_FILE=Qwen3VL-4B-Instruct-Q8_0.gguf
LLM_MMPROJ_FILE=mmproj-Qwen3VL-4B-Instruct-Q8_0.gguf

# Przykładowe stare polecenie z konsoli
# .\llama-server.exe -m ..\model\qwen3.5-9b.gguf --mmproj ..\model\mmproj-Qwen3.5-9B-BF16.gguf -ngl 99 -c 4096