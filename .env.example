# ── Email Configuration ──
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@iusfully.com

# Set to True to print emails to console instead of sending
MAIL_SUPPRESS_SEND=True

# ── App Security ──
# Wygeneruj: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── LLM / llama-server ──
LLAMA_SERVER_URL=http://127.0.0.1:8080/v1
MODEL_FILE=Qwen3VL-4B-Instruct-Q8_0.gguf
MMPROJ_FILE=mmproj-Qwen3VL-4B-Instruct-Q8_0.gguf
LLAMA_CONTEXT_SIZE=8000
LLM_MAX_TOKENS=1000
